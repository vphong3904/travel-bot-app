# ==== PostgreSQL ====
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/pdtrip_ai_db

# ==== MongoDB (logs, hành vi, audit) ====
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=pdtrip_ai_logs

# ==== Qdrant (vector DB) ====
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=pdtrip_knowledge
QDRANT_COLLECTION_KB_FILES=pdtrip_kb_files
QDRANT_API_KEY=

# ==== Gemini (LLM) ====
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=your-gemini-api-key

# ==== Embedding ====
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# ==== Auth / App ====
JWT_SECRET_KEY=change-me-to-a-long-random-string
APP_NAME=PDTrip AI
DEBUG=true
GOOGLE_CLIENT_ID=

# ==== RAG params ====
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.3
CHAT_HISTORY_LIMIT=10
KNOWLEDGE_SOURCE=hybrid

# ==== SMTP (gửi OTP email) ====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_USE_TLS=true
